model:
  default: opencode200k
  provider: custom:9router-8uoc.srv1699470.hstgr.cloud
agent:
  reasoning_effort: medium
browser:
  cloud_provider: local
  use_gateway: false
compression:
  enabled: true
  threshold: 0.8
  target_ratio: 0.2
auxiliary:
  vision:
    provider: custom:9router-8uoc.srv1699470.hstgr.cloud
    model: Vision
    base_url: https://9router-8uoc.srv1699470.hstgr.cloud/v1
    api_key: YOUR_API_KEY_HERE
    timeout: 180
  compression:
    provider: custom:9router-8uoc.srv1699470.hstgr.cloud
    model: context
    base_url: https://9router-8uoc.srv1699470.hstgr.cloud/v1
    timeout: 240
  web_extract:
    provider: custom:9router-8uoc.srv1699470.hstgr.cloud
    model: opencode200k
  approval:
    provider: custom:9router-8uoc.srv1699470.hstgr.cloud
    model: opencode200k
  mcp:
    provider: custom:9router-8uoc.srv1699470.hstgr.cloud
    model: opencode200k
  title_generation:
    provider: custom:9router-8uoc.srv1699470.hstgr.cloud
    model: context
    base_url: https://9router-8uoc.srv1699470.hstgr.cloud/v1
  skills_hub:
    provider: custom:9router-8uoc.srv1699470.hstgr.cloud
    model: opencode200k
  curator:
    provider: custom:9router-8uoc.srv1699470.hstgr.cloud
    model: opencode200k
  kanban_decomposer:
    provider: custom:9router-8uoc.srv1699470.hstgr.cloud
    model: opencode200k
  profile_describer:
    provider: custom:9router-8uoc.srv1699470.hstgr.cloud
    model: opencode200k
memory:
  memory_enabled: false
  user_profile_enabled: false
  provider: mnemosyne
  mnemosyne:
    auto_sleep: 'true'
    default_scope: session
    reflect: '{''disabled_for_cron'': True, ''max_calls_per_session'': 3}'
    shared_surface_path: data/shared/mnemosyne.db
    skip_contexts: cron,flush,subagent,background,skill_loop
    sleep_threshold: '50'
    sync_roles:
    - user
    vector_type: float32
delegation:
  model: opencode200k
  provider: custom
  base_url: https://9router-8uoc.srv1699470.hstgr.cloud/v1
  api_key: YOUR_API_KEY_HERE
  max_concurrent_children: 4
  max_spawn_depth: 2
  orchestrator_enabled: true
  fallback_models:
  - model: groq/openai/gpt-oss-120b
    provider: custom
  - model: groq/llama-3.3-70b-versatile
    provider: custom
  subagent:
    api_key: YOUR_API_KEY_HERE
    base_url: https://9router-8uoc.srv1699470.hstgr.cloud/v1
    fallback_models:
    - model: groq/openai/gpt-oss-120b
      provider: custom
    - model: groq/llama-3.3-70b-versatile
      provider: custom
    model: opencode200k
    provider: custom
