#!/bin/bash
# Gateway keepalive daemon — restarts gateway if it dies
# Run: nohup bash /home/hermeswebui/.hermes/scripts/gateway_daemon.sh &
# or: bash /home/hermeswebui/.hermes/scripts/gateway_daemon.sh &

export HERMES_HOME=/home/hermeswebui/.hermes
export PYTHONPATH=/home/hermeswebui/.hermes/hermes-agent

LOG="$HERMES_HOME/logs/daemon.log"
cd "$HERMES_HOME"

while true; do
    PID_FILE="$HERMES_HOME/gateway.pid"
    RUNNING=false

    if [ -f "$PID_FILE" ]; then
        PID=$(python3 -c "import json; print(json.load(open('$PID_FILE'))['pid'])" 2>/dev/null)
        if [ -n "$PID" ] && kill -0 "$PID" 2>/dev/null; then
            RUNNING=true
        fi
    fi

    if [ "$RUNNING" = false ]; then
        echo "[$(date -Iseconds)] Gateway not running — starting..." >> "$LOG"
        python3 -m hermes_cli.main gateway run >> "$HERMES_HOME/logs/gateway.log" 2>&1 &
        GW_PID=$!
        echo "[$(date -Iseconds)] Gateway started PID=$GW_PID" >> "$LOG"
        sleep 10  # give it time to connect
    fi

    sleep 30  # check every 30 seconds
done
